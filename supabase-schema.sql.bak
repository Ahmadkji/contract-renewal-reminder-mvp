-- ============================================
-- FIXED: Add user_id to every table
-- ============================================

CREATE TABLE contracts (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,

  -- FIX 1: user_id links every contract to a Supabase auth user.
  -- Without this column, RLS cannot isolate users from each other.
  user_id UUID NOT NULL REFERENCES auth.users(id) ON DELETE CASCADE,

  name TEXT NOT NULL,
  vendor TEXT NOT NULL,
  type TEXT NOT NULL CHECK (type IN ('license', 'service', 'support', 'subscription')),
  start_date DATE NOT NULL,
  end_date DATE NOT NULL,

  -- FIX: end_date must be after start_date — enforced at DB level
  CONSTRAINT end_after_start CHECK (end_date > start_date),

  value DECIMAL(10, 2),

  -- FIX (minor): constrain currency to known values
  currency TEXT DEFAULT 'USD' CHECK (currency IN ('USD', 'EUR', 'GBP', 'CAD', 'AUD')),

  -- FIX: Remove status from DB. It goes stale the moment time passes.
  -- Compute it in your query or application instead (see view below).
  -- status TEXT NOT NULL DEFAULT 'active' ... ← REMOVED

  auto_renew BOOLEAN DEFAULT false,
  renewal_terms TEXT,
  notes TEXT,
  tags TEXT[] DEFAULT '{}',

  -- FIX (minor): color is a UI concern, not a data concern.
  -- Store it in your frontend state or user preferences, not here.
  -- color TEXT DEFAULT '#06b6d4' ← REMOVED

  created_at TIMESTAMPTZ DEFAULT NOW(),
  updated_at TIMESTAMPTZ DEFAULT NOW()
);

CREATE TABLE vendor_contacts (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  contract_id UUID NOT NULL REFERENCES contracts(id) ON DELETE CASCADE,
  contact_name TEXT NOT NULL,
  email TEXT NOT NULL,
  -- FIX: basic email format guard at DB level
  CONSTRAINT valid_email CHECK (email ~* '^[^@]+@[^@]+\.[^@]+$'),
  created_at TIMESTAMPTZ DEFAULT NOW()
);

CREATE TABLE reminders (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  contract_id UUID NOT NULL REFERENCES contracts(id) ON DELETE CASCADE,

  -- FIX (minor): one row per reminder day, not an array.
  -- Makes querying "which reminders are due today" a simple WHERE clause.
  -- Instead of: WHERE 30 = ANY(reminder_days)
  -- You get:    WHERE days_before = 30
  days_before INTEGER NOT NULL CHECK (days_before > 0),

  notify_emails TEXT[] NOT NULL DEFAULT '{}',

  -- FIX 4: The most important column in the whole schema.
  -- Scheduler queries: WHERE sent_at IS NULL
  -- After sending:     UPDATE reminders SET sent_at = NOW()
  -- This makes sending idempotent — restart, redeploy, cron overlap = safe.
  sent_at TIMESTAMPTZ,

  -- Tracks failures so you can see what went wrong
  failed_at TIMESTAMPTZ,
  error_message TEXT,

  created_at TIMESTAMPTZ DEFAULT NOW()
);

-- ============================================
-- INDEXES
-- ============================================
CREATE INDEX idx_contracts_user_id ON contracts(user_id);
CREATE INDEX idx_contracts_end_date ON contracts(end_date);

-- Critical for scheduler: "find all unsent reminders due today"
CREATE INDEX idx_reminders_sent_at ON reminders(sent_at) WHERE sent_at IS NULL;

CREATE INDEX idx_vendor_contacts_contract_id ON vendor_contacts(contract_id);
CREATE INDEX idx_reminders_contract_id ON reminders(contract_id);

-- ============================================
-- UPDATED_AT TRIGGER (keep this, it's fine)
-- ============================================
CREATE OR REPLACE FUNCTION update_updated_at_column()
RETURNS TRIGGER AS $$
BEGIN
  NEW.updated_at = NOW();
  RETURN NEW;
END;
$$ language 'plpgsql';

CREATE TRIGGER update_contracts_updated_at
  BEFORE UPDATE ON contracts
  FOR EACH ROW
  EXECUTE FUNCTION update_updated_at_column();

-- ============================================
-- FIX: Remove the status trigger entirely.
-- Status computed on INSERT is immediately stale.
-- Use a computed view instead (below).
-- ============================================

-- ============================================
-- ROW LEVEL SECURITY — FIXED
-- ============================================
ALTER TABLE contracts ENABLE ROW LEVEL SECURITY;
ALTER TABLE vendor_contacts ENABLE ROW LEVEL SECURITY;
ALTER TABLE reminders ENABLE ROW LEVEL SECURITY;

-- FIX 2 + 3: Policies now check auth.uid() = user_id.
-- A logged-in user can ONLY see and modify their own contracts.
-- Anonymous users get nothing.

CREATE POLICY "Users manage own contracts" ON contracts
  FOR ALL
  TO authenticated
  USING (auth.uid() = user_id)
  WITH CHECK (auth.uid() = user_id);

-- vendor_contacts and reminders inherit isolation through
-- their foreign key to contracts — join ensures ownership.
CREATE POLICY "Users manage own vendor_contacts" ON vendor_contacts
  FOR ALL
  TO authenticated
  USING (
    EXISTS (
      SELECT 1 FROM contracts
      WHERE contracts.id = vendor_contacts.contract_id
        AND contracts.user_id = auth.uid()
    )
  );

CREATE POLICY "Users manage own reminders" ON reminders
  FOR ALL
  TO authenticated
  USING (
    EXISTS (
      SELECT 1 FROM contracts
      WHERE contracts.id = reminders.contract_id
        AND contracts.user_id = auth.uid()
    )
  );

-- ============================================
-- FIX: GRANT — remove anon write access
-- ============================================
-- anon gets SELECT only on nothing sensitive (Supabase handles auth endpoints)
-- authenticated gets what they need, RLS handles row isolation

GRANT USAGE ON SCHEMA public TO authenticated;
GRANT SELECT, INSERT, UPDATE, DELETE ON contracts TO authenticated;
GRANT SELECT, INSERT, UPDATE, DELETE ON vendor_contacts TO authenticated;
GRANT SELECT, INSERT, UPDATE, DELETE ON reminders TO authenticated;
GRANT EXECUTE ON FUNCTION update_updated_at_column TO authenticated;

-- ============================================
-- FIX: Status as a computed view, not a stored column
-- Status is always accurate because it's calculated at query time.
-- ============================================
CREATE OR REPLACE VIEW contract_stats AS
SELECT
  auth.uid() as user_id,
  COUNT(*) as total_contracts,
  COUNT(*) FILTER (WHERE CURRENT_DATE > end_date) as expired,
  COUNT(*) FILTER (WHERE end_date - CURRENT_DATE <= 7  AND CURRENT_DATE <= end_date) as critical,
  COUNT(*) FILTER (WHERE end_date - CURRENT_DATE <= 30 AND end_date - CURRENT_DATE > 7) as expiring,
  COUNT(*) FILTER (WHERE end_date - CURRENT_DATE > 30) as active,
  SUM(value) as total_value,
  AVG(value) as average_value
FROM contracts
-- FIX: Each user sees only their own stats
WHERE user_id = auth.uid();

-- ============================================
-- PROFILES TABLE
-- Stores user profile information for display and preferences
-- ============================================
CREATE TABLE profiles (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  user_id UUID NOT NULL REFERENCES auth.users(id) ON DELETE CASCADE UNIQUE,
  
  -- Basic profile info
  full_name TEXT,
  avatar_url TEXT,
  
  -- Preferences
  email_notifications BOOLEAN DEFAULT true,
  timezone TEXT DEFAULT 'UTC',
  
  -- Metadata
  created_at TIMESTAMPTZ DEFAULT NOW(),
  updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- Index for user_id lookups
CREATE INDEX idx_profiles_user_id ON profiles(user_id);

-- ============================================
-- ROW LEVEL SECURITY FOR PROFILES
-- ============================================
ALTER TABLE profiles ENABLE ROW LEVEL SECURITY;

-- Users can only see and modify their own profile
CREATE POLICY "Users manage own profile" ON profiles
  FOR ALL
  TO authenticated
  USING (auth.uid() = user_id)
  WITH CHECK (auth.uid() = user_id);

-- Grant permissions
GRANT SELECT, INSERT, UPDATE, DELETE ON profiles TO authenticated;

-- ============================================
-- UPDATED_AT TRIGGER FOR PROFILES
-- ============================================
CREATE TRIGGER update_profiles_updated_at
  BEFORE UPDATE ON profiles
  FOR EACH ROW
  EXECUTE FUNCTION update_updated_at_column();