# ============================================
# App: Public Runtime Variables
# ============================================
NEXT_PUBLIC_APP_URL=https://your-app.example.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_public_anon_key
NEXT_PUBLIC_SUPPORT_EMAIL=support@your-domain.example.com

# ============================================
# App: Server-Only Secrets / Credentials
# ============================================
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
CRON_SECRET=replace_with_a_long_random_secret

# ============================================
# Billing (Creem)
# ============================================
CREEM_API_KEY=your_creem_api_key
CREEM_WEBHOOK_SECRET=your_creem_webhook_secret
CREEM_API_BASE_URL=https://api.creem.io
CREEM_MONTHLY_PRODUCT_ID=your_creem_monthly_product_id
CREEM_YEARLY_PRODUCT_ID=your_creem_yearly_product_id

# ============================================
# Email (Resend)
# ============================================
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=reminders@your-domain.example.com
RESEND_FROM_NAME=Remindely

# ============================================
# Security / Observability
# ============================================
CSRF_TRUSTED_ORIGINS=https://your-app.example.com,https://staging.your-app.example.com
RATE_LIMIT_TRUST_PROXY_HEADERS=1
ERROR_TRACKING_WEBHOOK_URL=https://your-observability-endpoint.example.com/webhook
ALERTING_WEBHOOK_URL=https://your-alerting-endpoint.example.com/webhook

# ============================================
# Optional Performance Tuning
# ============================================
CHECKOUT_SESSION_DEDUPE_TTL_MS=30000
CONTRACTS_PAGE_CACHE_TTL_MS=1500
SESSION_VALIDATION_CACHE_TTL_MS=30000
CONTRACTS_API_TIMING_LOGS=0

# ============================================
# Optional Platform Flags (usually set by host)
# ============================================
NODE_ENV=development
CI=0
VERCEL=1
CF_PAGES=0

# ============================================
# E2E / Integration Test Variables
# ============================================
TEST_EMAIL=test-user@example.com
TEST_PASSWORD=change_me_for_test_only

BILLING_TEST_APP_PORT=3200
BILLING_TEST_CREEM_PORT=4200

SUBSCRIPTION_TEST_LANE=deterministic
SUBSCRIPTION_TEST_APP_PORT=3020
SUBSCRIPTION_TEST_CREEM_PORT=4010
SUBSCRIPTION_TEST_PUBLIC_APP_URL=http://127.0.0.1:3020
SUBSCRIPTION_TEST_REQUEST_ORIGIN=http://127.0.0.1:3020

REMINDER_TEST_APP_PORT=3022
REMINDER_TEST_TIMEOUT_MS=120000
REMINDER_TEST_VERBOSE=0

# ============================================
# Ops Script Variables
# ============================================
OPS_CONTRACTS_EXPLAIN_STRICT=0
CONTRACTS_EXPLAIN_USER_ID=00000000-0000-0000-0000-000000000000
REMINDER_CLAIM_TIMEOUT_SECONDS=900
REMINDER_STUCK_CLAIM_ALERT_THRESHOLD=1800

# ============================================
# Load Test Variables
# ============================================
LOAD_TEST_APP_MODE=production
LOAD_TEST_APP_PORT=3100
LOAD_TEST_CREEM_PORT=4110
LOAD_TEST_TIMEOUT_MS=180000
LOAD_TEST_RUN_SOAK=1
LOAD_TEST_ONLY_CAPACITY=0
LOAD_TEST_MAX_CONCURRENCY=50
LOAD_TEST_SOAK_DURATION_MS=3600000
LOAD_TEST_SOAK_CONCURRENCY=50
LOAD_TEST_SOAK_SMOKE_DURATION_MS=120000
LOAD_TEST_CAPACITY_STAGES=10,20,30,40,50
LOAD_TEST_CAPACITY_STAGE_DURATION_MS=15000
LOAD_TEST_DB_DIAGNOSTIC_POLL_MS=10000
LOAD_TEST_DIAGNOSTIC_CLAIM_TIMEOUT_SECONDS=900
LOAD_TEST_SESSION_REFRESH_MAX_AGE_MS=180000
LOAD_TEST_VERBOSE_SERVER=0
